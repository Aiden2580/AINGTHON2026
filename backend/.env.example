# Google Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# JWT signing secret — change this to a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string

# 국회 의안정보 통합 Open API key (open.assembly.go.kr)
# Service: 의안정보 통합 (TVBPMBILL11)
# Used by /policies/refresh to pull real bill data from the government.
OPENAPI_KEY=your_openapi_key_here

# (Optional) National Assembly term (대수). 22 = 제22대 국회 (current).
# OPENAPI_AGE=22

# (Optional) Override the default endpoint URL.
# OPENAPI_BILLS_URL=https://open.assembly.go.kr/portal/openapi/TVBPMBILL11
