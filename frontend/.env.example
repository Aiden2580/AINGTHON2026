# Backend API URL — leave commented to use Platform-aware default:
#   Android emulator → http://10.0.2.2:8000
#   iOS sim / web    → http://localhost:8000
#
# For physical devices, set this to your machine's LAN IP:
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
#
# For deployed backends:
#   EXPO_PUBLIC_API_URL=https://your-backend.example.com
